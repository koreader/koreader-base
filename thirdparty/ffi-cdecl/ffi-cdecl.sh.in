#!/bin/bash

set -eo pipefail

TARGET_CC=(@TARGET_CC@)
TARGET_CXX=(@TARGET_CXX@)
PLUGIN_CC=(@PLUGIN_CC@)
PLUGIN_CXX=(@PLUGIN_CXX@)
PREFIX=@PREFIX@

if [[ -t 2 ]] || [[ -n "${CLICOLOR_FORCE}" ]]; then
    declare -r ANSI_BLUE='\33[34;1m'
    declare -r ANSI_RESET='\33[0m'
else
    declare -r ANSI_BLUE=''
    declare -r ANSI_RESET=''
fi

printq() {
    printf '%q' "$1"
    shift
    [[ $# -eq 0 ]] || printf ' %q' "$@"
    printf '\n'
}

usage() {
    cat 1>&2 <<-EOF
usage: ffi-cdecl [-c language] [-d dependency] [-o output.lua] [-n] [-D…|-I…|-U…]* input.c

    -c language    Select language: c or c++ (otherwise determined by the input extension)
    -d dependency  Add additional cflags from specified pkg-config dependency
    -o output      Set output file (instead of stdout)
    -f flags       Extra flags forwarded to the compiler

    -D/-I/-U       Those flags are forwarded to the compiler

    -n             Dry-run, show final commands only
EOF
    exit 1
}

[[ $# -gt 0 ]] || usage

pkg-config() {
    env \
        PKG_CONFIG_PATH="${PREFIX}/lib/pkgconfig" \
        pkg-config --env-only --cflags "$@"
}

language=''
dry_run=''
output='-'
verbose=0

cflags=(
    -I"${PREFIX}/include/ffi-cdecl"
    -I"${PREFIX}/include"
)

while getopts 'c:d:f:o:D:I:U:h:nv' opt; do
    case "${opt}" in
        c)
            case "${OPTARG}" in
                c | c++)
                    language="${OPTARG}"
                    ;;
                *)
                    usage
                    ;;
            esac
            ;;
        d)
            read -ra a < <(pkg-config --cflags "${OPTARG}")
            cflags+=("${a[@]}")
            ;;
        f)
            declare -a "a=(${OPTARG})"
            cflags+=("${a[@]}")
            ;;
        n)
            dry_run=1
            ;;
        o)
            output="${OPTARG}"
            ;;
        v)
            verbose=$((verbose + 1))
            ;;
        [DIU])
            cflags+=("-${opt}${OPTARG}")
            ;;
        [h?])
            usage
            ;;
    esac
done

shift $((OPTIND - 1))

[[ $# -eq 1 ]] || usage

if [[ -z "${language}" ]]; then
    case "$1" in
        *.C | *.cc | *.cpp | *.CPP | *.c++ | *.cp | *.cxx)
            language='c++'
            ;;
        *)
            language='c'
            ;;
    esac
fi

case "${language}" in
    c)
        target_compiler=("${TARGET_CC[@]}")
        plugin_compiler=("${PLUGIN_CC[@]}")
        ;;
    c++)
        target_compiler=("${TARGET_CXX[@]}")
        plugin_compiler=("${PLUGIN_CXX[@]}")
        ;;
esac

target_cmd=()
plugin_cmd=()

target_cmd+=("${cflags[@]}")

plugin_cmd+=(
    -fplugin="${PREFIX}/lib/gcc/plugin/gcclua.so"
    -fplugin-arg-gcclua-script="${PREFIX}/share/lua/5.1/ffi-cdecl.lua"
    -fplugin-arg-gcclua-output=-
    -S
    -o /dev/null
)

# shellcheck disable=2034
fixups_cmd=(
    sed
    # Clang.
    -e '/^typedef __float128 _Float128;$/d'
    -e '/^typedef float _Float32;$/d'
    -e '/^typedef double _Float64;$/d'
    -e '/^typedef double _Float32x;$/d'
    -e '/^typedef long double _Float64x;$/d'
    # Android.
    -e 's/\<__availability__(android[^)]*)//'
    -e '/^int ioctl(int __fd, unsigned __request, \.\.\.) __attribute__((overloadable))/d'
)

if [[ "${plugin_compiler[0]}" == "${target_compiler[0]}" ]]; then
    target_cmd=("${target_compiler[@]}" "${target_cmd[@]}" "${plugin_cmd[@]}" "$1")
    different_compilers=''
else
    target_cmd=("${target_compiler[@]}" "${target_cmd[@]}" -E -P "$1")
    plugin_cmd=("${plugin_compiler[@]}" "${plugin_cmd[@]}" -x "${language}" -)
    different_compilers=1
fi

pipe=''
result=''
for cmd in target_cmd ${different_compilers:+fixups_cmd} ${different_compilers:+plugin_cmd}; do
    eval "set -- \"\${${cmd}[@]}\""
    if [[ -n "${dry_run}" ]] || [[ ${verbose} -gt 0 ]]; then
        printf '%b' "${ANSI_BLUE}"
        printf '%s ' ▹ ${pipe:+|}
        printq "$@" 1>&2
        printf '%b' "${ANSI_RESET}"
    fi
    if [[ -z "${dry_run}" ]]; then
        result="$("$@" <<<"${result}")"
        if [[ ${verbose} -gt 1 ]]; then
            printf '%s\n' "${result}" 1>&2
        fi
    fi
    pipe=1
done

if [[ -n "${dry_run}" ]]; then
    exit
fi

if [[ "${output}" != '-' ]]; then
    exec >"${output}"
fi

printf -- '-- Automatically generated with ffi-cdecl.\n\n'
printf '%s\n' "${result}"

# vim: sw=4
