set(REMOVE_ON_ERROR "")

function(run)
    execute_process(${ARGN} RESULT_VARIABLE RET)
    if(NOT RET EQUAL 0)
        if(REMOVE_ON_ERROR)
            file(REMOVE ${REMOVE_ON_ERROR})
        endif()
        list(SUBLIST ARGN 1 -1 CMD)
        list(JOIN CMD " " CMD)
        message(FATAL_ERROR "command failed (${RET}): ${CMD}")
    endif()
endfunction()

function(strip SRC DST)
    list(APPEND STRIP -o "${DST}" "${SRC}")
    run(${STRIP})
endfunction()

if(CMAKE_VERSION VERSION_GREATER_EQUAL "3.21")
    function(copy SRC DST)
        file(COPY_FILE "${SRC}" "${DST}")
    endfunction()
else()
    function(copy SRC DST)
        run(COMMAND "${CMAKE_COMMAND}" -E copy "${SRC}" "${DST}")
    endfunction()
endif()


function(install_binary)
    if(NOT "${SRC}" IS_NEWER_THAN "${DST}")
        return()
    endif()
    set(REMOVE_ON_ERROR "${DST}" PARENT_SCOPE)
    get_filename_component(DIR "${DST}" DIRECTORY)
    file(MAKE_DIRECTORY "${DIR}")
    if(STRIP)
        strip("${SRC}" "${DST}")
    else()
        copy("${SRC}" "${DST}")
    endif()
endfunction()


function(install_shared_lib)
    if(NOT "${SHLIB}" IS_NEWER_THAN "${STAGING}/${VERSIONED}")
        return()
    endif()
    set(REMOVE_ON_ERROR "${LIBS}/${VERSIONED}" "${STAGING}/${VERSIONED}" "${STAGING}/${BASE}" PARENT_SCOPE)
    get_filename_component(LIBS "${LIBS}" ABSOLUTE)
    file(MAKE_DIRECTORY "${LIBS}" "${STAGING}")
    if(STRIP)
        strip("${SHLIB}" "${LIBS}/${VERSIONED}")
    else()
        copy("${SHLIB}" "${LIBS}/${VERSIONED}")
    endif()
    file(CREATE_LINK "${LIBS}/${VERSIONED}" "${STAGING}/${VERSIONED}" SYMBOLIC)
    if(NOT BASE STREQUAL VERSIONED)
        file(CREATE_LINK "${VERSIONED}" "${STAGING}/${BASE}" SYMBOLIC)
    endif()
endfunction()


function(install_static_lib)
    if(NOT "${STLIB}" IS_NEWER_THAN "${STAGING}/${LIBNAME}")
        return()
    endif()
    file(MAKE_DIRECTORY "${STAGING}")
    copy("${STLIB}" "${STAGING}/${LIBNAME}")
endfunction()


if(MODE STREQUAL "binary")
    install_binary()
elseif(MODE STREQUAL "shared_lib")
    install_shared_lib()
elseif(MODE STREQUAL "static_lib")
    install_static_lib()
else()
    message(FATAL_ERROR "unsupported mode: ${MODE}")
endif()
