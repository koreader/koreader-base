+++ b/sharedlib/CMakeLists.txt
@@ -30,6 +30,7 @@ if(WITH_SIMD AND (MSVC_IDE OR XCODE))
   set_source_files_properties(${SIMD_OBJS} PROPERTIES GENERATED 1)
 endif()
 
+if(FALSE)
 if(WITH_TURBOJPEG OR WITH_TOOLS OR WITH_TESTS)
   if(WITH_SYSTEM_SPNG)
     unset(SPNG_SOURCES)
@@ -43,6 +44,7 @@ if(WITH_TURBOJPEG OR WITH_TOOLS OR WITH_TESTS)
     set(ZLIB_SOURCES $<TARGET_OBJECTS:zlib>)
   endif()
 endif()
+endif()
 
 if(WIN32)
   set(DEFFILE ../win/jpeg${SO_MAJOR_VERSION}.def)
