diff --git a/CMakeLists.txt b/CMakeLists.txt
index 672d93a..3aa7814 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -725,6 +725,7 @@ if(WITH_JNA)
   add_subdirectory(jna)
 endif()
 
+if(FALSE)
 if(WITH_TURBOJPEG OR WITH_TOOLS OR WITH_TESTS)
   option(WITH_SYSTEM_SPNG
     "Build ${CMAKE_PROJECT_NAME} against the system-supplied libspng implementation rather than the implementation in the ${CMAKE_PROJECT_NAME} source tree"
@@ -755,6 +756,7 @@ if(WITH_TURBOJPEG OR WITH_TOOLS OR WITH_TESTS)
     unset(ZLIB_LIBRARY)
   endif()
 endif()
+endif()
 
 if(ENABLE_SHARED)
   add_subdirectory(sharedlib)
@@ -794,8 +796,7 @@ if(WITH_TURBOJPEG)
     if(NOT WITH_SYSTEM_SPNG AND ZLIB_LIBRARY)
       target_link_libraries(turbojpeg ${ZLIB_LIBRARY})
     endif()
-    set_property(TARGET turbojpeg PROPERTY COMPILE_FLAGS
-      "-DBMP_SUPPORTED -DPNG_SUPPORTED -DSPNG_STATIC -DPPM_SUPPORTED")
+    set_property(TARGET turbojpeg PROPERTY COMPILE_FLAGS -DBMP_SUPPORTED)
     if(WIN32)
       set_target_properties(turbojpeg PROPERTIES DEFINE_SYMBOL DLLDEFINE)
     endif()
@@ -851,8 +851,7 @@ if(WITH_TURBOJPEG)
     if(NOT WITH_SYSTEM_SPNG AND ZLIB_LIBRARY)
       target_link_libraries(turbojpeg-static ${ZLIB_LIBRARY})
     endif()
-    set_property(TARGET turbojpeg-static PROPERTY COMPILE_FLAGS
-      "-DBMP_SUPPORTED -DPNG_SUPPORTED -DSPNG_STATIC -DPPM_SUPPORTED")
+    set_property(TARGET turbojpeg-static PROPERTY COMPILE_FLAGS -DBMP_SUPPORTED)
     if(NOT MSVC_LIKE)
       set_target_properties(turbojpeg-static PROPERTIES OUTPUT_NAME turbojpeg)
     endif()
diff --git a/sharedlib/CMakeLists.txt b/sharedlib/CMakeLists.txt
